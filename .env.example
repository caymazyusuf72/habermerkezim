# Haber Merkezi Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun

# API Keys
NEWS_API_KEY=your_news_api_key_here
WEATHER_API_KEY=your_weather_api_key_here

# Firebase Configuration (Optional - already in google-services.json)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_project_id

# App Configuration
APP_NAME=Haber Merkezi
APP_VERSION=1.0.0
DEBUG_MODE=false

# RSS Feed Configuration
RSS_CACHE_DURATION_MINUTES=15
RSS_REQUEST_TIMEOUT_SECONDS=10

# Analytics
ANALYTICS_ENABLED=true

# Feature Flags
FEATURE_GAMIFICATION=true
FEATURE_DARK_MODE=true
FEATURE_NOTIFICATIONS=true
FEATURE_OFFLINE_MODE=true