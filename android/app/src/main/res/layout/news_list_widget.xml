<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_list_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="@dimen/widget_padding">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/widget_item_spacing">

        <ImageView
            android:layout_width="@dimen/widget_icon_size_small"
            android:layout_height="@dimen/widget_icon_size_small"
            android:src="@mipmap/launcher_icon"
            android:contentDescription="Haber Merkezi"
            android:layout_marginEnd="@dimen/widget_item_spacing_small" />

        <TextView
            android:id="@+id/widget_list_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Son Haberler"
            android:textSize="@dimen/widget_text_header"
            android:textStyle="bold"
            android:textColor="@color/widget_primary" />
    </LinearLayout>

    <!-- 1. Haber -->
    <TextView
        android:id="@+id/widget_list_title_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Haber 1"
        android:textSize="@dimen/widget_text_body"
        android:textStyle="bold"
        android:textColor="@color/widget_text_primary"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingTop="@dimen/widget_item_spacing_small"
        android:paddingBottom="@dimen/widget_item_spacing_small" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/widget_divider_height"
        android:background="@color/widget_divider" />

    <!-- 2. Haber -->
    <TextView
        android:id="@+id/widget_list_title_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Haber 2"
        android:textSize="@dimen/widget_text_body"
        android:textStyle="bold"
        android:textColor="@color/widget_text_primary"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingTop="@dimen/widget_item_spacing_small"
        android:paddingBottom="@dimen/widget_item_spacing_small" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/widget_divider_height"
        android:background="@color/widget_divider" />

    <!-- 3. Haber -->
    <TextView
        android:id="@+id/widget_list_title_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Haber 3"
        android:textSize="@dimen/widget_text_body"
        android:textStyle="bold"
        android:textColor="@color/widget_text_primary"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingTop="@dimen/widget_item_spacing_small"
        android:paddingBottom="@dimen/widget_item_spacing_small" />
</LinearLayout>
