<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_category_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/widget_background"
    android:padding="@dimen/widget_padding_small"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/widget_cat_genel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="GENEL"
        android:textSize="@dimen/widget_text_body"
        android:textStyle="bold"
        android:textColor="@color/widget_on_primary"
        android:background="@drawable/widget_background_gradient"
        android:gravity="center"
        android:padding="@dimen/widget_padding_small"
        android:layout_marginEnd="@dimen/widget_item_spacing_small" />

    <TextView
        android:id="@+id/widget_cat_teknoloji"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="TEKNOLOJİ"
        android:textSize="@dimen/widget_text_body"
        android:textStyle="bold"
        android:textColor="@color/widget_on_primary"
        android:background="@drawable/widget_background_gradient"
        android:gravity="center"
        android:padding="@dimen/widget_padding_small"
        android:layout_marginEnd="@dimen/widget_item_spacing_small" />

    <TextView
        android:id="@+id/widget_cat_ekonomi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="EKONOMİ"
        android:textSize="@dimen/widget_text_body"
        android:textStyle="bold"
        android:textColor="@color/widget_on_primary"
        android:background="@drawable/widget_background_gradient"
        android:gravity="center"
        android:padding="@dimen/widget_padding_small" />
</LinearLayout>