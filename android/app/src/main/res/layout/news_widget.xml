<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/widget_dark_bg"
    android:clickable="true"
    android:focusable="true"
    android:padding="0dp">
    
    <!-- Üst çizgi (progress indicator) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/widget_purple" />
    
    <!-- Ana Banner Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/widget_dark_bg">
        
        <!-- Hamburger Menu Icon (görünür ama tıklanamaz) -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_more"
            android:tint="#9C27B0"
            android:contentDescription="Menu"
            android:layout_marginEnd="8dp" />
        
        <!-- SON DAKİKA Rozeti -->
        <TextView
            android:id="@+id/widget_breaking_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SON DAKİKA"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@color/widget_purple"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="8dp"
            android:gravity="center" />
        
        <!-- Haber Başlığı (kaydırılabilir) -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Haberler yükleniyor..."
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scrollHorizontally="true"
            android:layout_marginEnd="8dp" />
        
        <!-- İleri Butonu (sağ ok) -->
        <ImageButton
            android:id="@+id/widget_next_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_next"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#9C27B0"
            android:contentDescription="Sonraki"
            android:padding="4dp"
            android:layout_marginEnd="4dp" />
        
        <!-- Duraklat/Oynat Butonu -->
        <ImageButton
            android:id="@+id/widget_play_pause_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_pause"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#9C27B0"
            android:contentDescription="Duraklat/Oynat"
            android:padding="4dp" />
    </LinearLayout>
    
</LinearLayout>
